# Copy to .env and fill in. Never commit .env.
# OpenAI (chat, uploads, marketing helpers, legacy AI_API_KEY via config_ai.php)
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# WhatsApp Cloud API (Meta) — used by status notifications, commission alerts,
# task-assignment monitor "Notify staff", etc.
# ---------------------------------------------------------------------------
# Primary token (preferred). Legacy bots may use WHATSAPP_TOKEN instead.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: national numbers without country code (digits only, e.g. 1, 234, 44)
WHATSAPP_DEFAULT_COUNTRY_CODE=
# Graph API version (default v19.0 if empty)
META_GRAPH_VERSION=

# --- Task assignment monitor: "Notify staff" WhatsApp (Utility templates in Meta) ---
# Code defaults to template names pcvc_staff_task_utility (standard) and pcvc_staff_task_utility_urgent
# (urgent). Override with the variables below if you used different names in Meta.
# Body in Meta: {{1}} staff name (admins), {{2}} company display name + " — " + sender from admins + " #" + id, {{3}} supervisor comments from modal.
# See helpers/task_staff_whatsapp_notify.php header comment for copy-paste body text.
WHATSAPP_TASK_STAFF_TEMPLATE_NAME=
WHATSAPP_TASK_STAFF_TEMPLATE_LANG=en
WHATSAPP_TASK_STAFF_TEMPLATE_PARAMS=3
WHATSAPP_TASK_STAFF_TEMPLATE_URGENT_NAME=

# --- Refund request WhatsApp (Utility template in Meta) ---
# Default template name in code: pcvc_refund_update
# Register a NEW template in Meta (7 body variables) — see helpers/refund_status_notify.php for copy-paste body.
#
# {{1}} student name
# {{2}} reference ID
# {{3}} status label
# {{4}} service paid for
# {{5}} amount + currency
# {{6}} admin comment (part 1, up to ~900 chars)
# {{7}} admin comment (part 2, continuation or "—")
#
# Set WHATSAPP_REFUND_TEMPLATE_PARAMS=4 only if you still use the old 4-variable template.
WHATSAPP_REFUND_TEMPLATE_NAME=
WHATSAPP_REFUND_TEMPLATE_LANG=en
WHATSAPP_REFUND_TEMPLATE_PARAMS=7

# --- Commission request WhatsApp (Utility template in Meta) ---
# Default template name in code: pcvc_commission_update
# Use 4 body variables (recommended) — Meta rejects templates with too many variables vs static text.
#
# Copy-paste body for Meta (4 variables — should pass Meta validation):
#
# Hello {{1}},
#
# Thank you for working with Parrot Canada Visa Consultant. We have reviewed your commission request {{2}} and updated its status in our system.
#
# Current status: {{3}}
#
# Details from our team:
# {{4}}
#
# If you have questions about this update, please reply to this message or contact our office during business hours. We appreciate your continued partnership.
#
# {{1}} agent full name
# {{2}} request reference (e.g. #42)
# {{3}} status label (e.g. Rejected)
# {{4}} student name + rejection reason / message (combined by the app)
#
# Optional: WHATSAPP_COMMISSION_TEMPLATE_PARAMS=5 or 6 if you register a longer template in Meta.
WHATSAPP_COMMISSION_TEMPLATE_NAME=
WHATSAPP_COMMISSION_TEMPLATE_LANG=en
WHATSAPP_COMMISSION_TEMPLATE_PARAMS=4

# WhatsApp Cloud API bot (whatsapp-bot/config.php) — optional separate bot stack
WHATSAPP_OPENAI_KEY=
WHATSAPP_DB_HOST=
WHATSAPP_DB_USER=
WHATSAPP_DB_PASS=
WHATSAPP_DB_NAME=

# Payments / MoPay / Stripe — see payments/config.php
# PAYMENT_APP_ENV=
# MOPAY_ACCOUNT_ID=
# MOPAY_AUTH_KEY=
# STRIPE_SECRET_KEY=
