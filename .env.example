# Copy to .env and fill in. Never commit .env.
# OpenAI (chat, uploads, marketing helpers, legacy AI_API_KEY via config_ai.php)
OPENAI_API_KEY=

# WhatsApp Cloud API bot (whatsapp-bot/config.php)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: separate model key for the bot; defaults to OPENAI_API_KEY
WHATSAPP_OPENAI_KEY=
# Bot database — falls back to DB_* if unset
WHATSAPP_DB_HOST=
WHATSAPP_DB_USER=
WHATSAPP_DB_PASS=
WHATSAPP_DB_NAME=

# Payments / MoPay / Stripe — see payments/config.php
# PAYMENT_APP_ENV=
# MOPAY_ACCOUNT_ID=
# MOPAY_AUTH_KEY=
# STRIPE_SECRET_KEY=
